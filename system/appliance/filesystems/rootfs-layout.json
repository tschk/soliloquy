{
  "schema_version": 1,
  "target": "soliloquy-a527-browser-appliance",
  "root": {
    "mountpoint": "/",
    "role": "immutable-system",
    "format_preference": [
      "solfs",
      "erofs",
      "squashfs"
    ],
    "mount_options": [
      "ro",
      "nodev"
    ],
    "boot_policy": {
      "default_mode": "ram-root",
      "selection": "auto",
      "minimum_ram_mb": 3072,
      "fallback_mode": "disk-root",
      "fallback_device": "/dev/vda",
      "fallback_fstype": "ext4",
      "kernel_arg": "soliloquy.ram_root"
    },
    "generation_root": "/sysroot/soliloquy",
    "active_generation_link": "/sysroot/soliloquy/current",
    "metadata_path": "/etc/soliloquy/generation.json",
    "runtime_status_path": "/run/soliloquy/rootfs.env",
    "rollback_generations": 2
  },
  "generation": {
    "id": "soliloquy-0001",
    "status": "pending-good",
    "mark_good_hook": "/usr/local/bin/soliloquy-generation-mark-good",
    "state_path": "/var/lib/soliloquy/system/update-state.json"
  },
  "immutable_paths": [
    "/bin",
    "/boot",
    "/etc",
    "/lib",
    "/sbin",
    "/usr"
  ],
  "runtime_tmpfs": [
    {
      "path": "/run",
      "mode": "0755",
      "options": [
        "nosuid",
        "nodev",
        "mode=0755"
      ]
    },
    {
      "path": "/tmp",
      "mode": "0755",
      "options": [
        "nosuid",
        "nodev",
        "mode=0755"
      ]
    },
    {
      "path": "/dev/shm",
      "mode": "1777",
      "options": [
        "nosuid",
        "nodev",
        "mode=1777",
        "size=256m"
      ]
    }
  ],
  "state_manifest": "/etc/soliloquy/filesystems/state-mounts.json",
  "sealed_inputs": [
    "/etc/soliloquy/world",
    "/etc/soliloquy/backend.json",
    "/etc/soliloquy/kernel-policy.json",
    "/etc/soliloquy/services.json",
    "/etc/soliloquy/system.json",
    "/etc/soliloquy/update-policy.json"
  ]
}
