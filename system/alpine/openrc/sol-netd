#!/sbin/openrc-run

description="Soliloquy network state daemon"

command="/usr/local/bin/sol-netd"
command_background="yes"
pidfile="/run/${RC_SVCNAME}.pid"
export SOLILOQUY_NETD_STATE_JSON="${SOLILOQUY_NETD_STATE_JSON:-/run/soliloquy/netd/interfaces.json}"
export SOLILOQUY_NETD_RUNTIME_ENV="${SOLILOQUY_NETD_RUNTIME_ENV:-/run/soliloquy/netd/runtime-state.env}"
export SOLILOQUY_NETD_INTERVAL_SECS="${SOLILOQUY_NETD_INTERVAL_SECS:-5}"

depend() {
    need localmount networking sol-kernel-policy
    before sold sol-session
}
