{
  "services": [
    {
      "id": "networking",
      "display_name": "Network",
      "run_as": "root",
      "restart": "system",
      "dependencies": [],
      "state_paths": []
    },
    {
      "id": "seatd",
      "display_name": "Seat Management",
      "run_as": "root",
      "restart": "always",
      "dependencies": [],
      "state_paths": [
        "/run/seatd.sock"
      ]
    },
    {
      "id": "sol-kernel-policy",
      "display_name": "Kernel Policy",
      "run_as": "root",
      "restart": "system",
      "dependencies": [],
      "state_paths": [
        "/sys/fs/cgroup/soliloquy",
        "/run/soliloquy/runtime-state.env"
      ]
    },
    {
      "id": "sol-netd",
      "display_name": "Network State Daemon",
      "run_as": "root",
      "restart": "always",
      "dependencies": [
        "networking",
        "sol-kernel-policy"
      ],
      "state_paths": [
        "/run/soliloquy/netd/interfaces.json",
        "/run/soliloquy/netd/runtime-state.env"
      ]
    },
    {
      "id": "sold",
      "display_name": "Soliloquy Local Server",
      "run_as": "sold",
      "restart": "always",
      "dependencies": [
        "networking",
        "sol-netd",
        "sol-kernel-policy",
        "sol-zram",
        "sol-pressure"
      ],
      "state_paths": [
        "/var/lib/soliloquy/system",
        "/var/log/soliloquy"
      ]
    },
    {
      "id": "sol-session",
      "display_name": "Soliloquy Session",
      "run_as": "root",
      "restart": "always",
      "dependencies": [
        "sold",
        "seatd",
        "sol-zram",
        "sol-pressure"
      ],
      "state_paths": [
        "/run/user/0",
        "/var/lib/soliloquy/browser"
      ]
    },
    {
      "id": "sol-zram",
      "display_name": "Compressed Swap",
      "run_as": "root",
      "restart": "system",
      "dependencies": [
        "sol-kernel-policy"
      ],
      "state_paths": [
        "/dev/zram0",
        "/proc/swaps",
        "/run/soliloquy/runtime-state.env"
      ]
    },
    {
      "id": "sol-pressure",
      "display_name": "Pressure Policy",
      "run_as": "root",
      "restart": "always",
      "dependencies": [
        "sol-kernel-policy",
        "sol-zram"
      ],
      "state_paths": [
        "/proc/pressure",
        "/sys/fs/cgroup/soliloquy",
        "/run/soliloquy/runtime-state.env"
      ]
    },
    {
      "id": "remote-sync",
      "display_name": "Remote Sync Plugin",
      "run_as": "sold",
      "restart": "on-failure",
      "dependencies": [
        "sold"
      ],
      "optional": true,
      "state_paths": [
        "/var/lib/soliloquy/system/plugins"
      ]
    }
  ]
}
