#!/bin/sh
set -eu

if [ -f /etc/conf.d/sol-session ]; then
  # shellcheck disable=SC1091
  . /etc/conf.d/sol-session
fi

export XDG_RUNTIME_DIR="/run/user/$(id -u)"
export WLR_BACKENDS="${WLR_BACKENDS:-drm,libinput}"
# Pixman keeps the compositor on a predictable software path in tiny VMs. Override via
# /etc/conf.d/sol-session (WLR_RENDERER=gles2) when GLES is preferred on real hardware.
export WLR_RENDERER="${WLR_RENDERER:-pixman}"
export WLR_RENDERER_ALLOW_SOFTWARE="${WLR_RENDERER_ALLOW_SOFTWARE:-1}"
# Avoid hardware cursor paths that occasionally break under virtio/llvmpipe in VMs.
export WLR_NO_HARDWARE_CURSORS="${WLR_NO_HARDWARE_CURSORS:-1}"
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"
export SERVO_DISPLAY_BACKEND="${SERVO_DISPLAY_BACKEND:-wayland}"
export WINIT_UNIX_BACKEND="${WINIT_UNIX_BACKEND:-wayland}"
export EGL_PLATFORM="${EGL_PLATFORM:-wayland}"
export SOL_TOKEN="${SOL_TOKEN:-dev-token-change-me}"
export SOLILOQUY_HOME="${SOLILOQUY_HOME:-/var/lib/soliloquy}"
export SOLILOQUY_SYSTEM_CONFIG="${SOLILOQUY_SYSTEM_CONFIG:-/etc/soliloquy/system.json}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-${SOLILOQUY_HOME}/data}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${SOLILOQUY_HOME}/cache}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-${SOLILOQUY_HOME}/config}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-${SOLILOQUY_HOME}/state}"
export SOLILOQUY_PROFILE_DIR="${SOLILOQUY_PROFILE_DIR:-${SOLILOQUY_HOME}/browser/profiles/default}"
export SOLILOQUY_CACHE_DIR="${SOLILOQUY_CACHE_DIR:-${SOLILOQUY_HOME}/browser/cache}"
export SOLILOQUY_DOWNLOADS_DIR="${SOLILOQUY_DOWNLOADS_DIR:-${SOLILOQUY_HOME}/browser/downloads}"
export SOLILOQUY_STATE_DIR="${SOLILOQUY_STATE_DIR:-${SOLILOQUY_HOME}/browser/state}"
export SOLILOQUY_LOG_DIR="${SOLILOQUY_LOG_DIR:-${SOLILOQUY_HOME}/browser/logs}"
export SOLILOQUY_TERMINAL_STATE_DIR="${SOLILOQUY_TERMINAL_STATE_DIR:-${SOLILOQUY_HOME}/browser/terminal}"
export SOLILOQUY_RUNTIME_STATE_ENV="${SOLILOQUY_RUNTIME_STATE_ENV:-/run/soliloquy/runtime-state.env}"
SERIAL_CONSOLE="${SERIAL_CONSOLE:-/dev/ttyS0}"

mkdir -p "${XDG_RUNTIME_DIR}"
mkdir -p "$(dirname "${SOLILOQUY_RUNTIME_STATE_ENV}")"
mkdir -p \
  "${XDG_DATA_HOME}" \
  "${XDG_CACHE_HOME}" \
  "${XDG_CONFIG_HOME}" \
  "${XDG_STATE_HOME}" \
  "${SOLILOQUY_PROFILE_DIR}" \
  "${SOLILOQUY_CACHE_DIR}" \
  "${SOLILOQUY_DOWNLOADS_DIR}" \
  "${SOLILOQUY_STATE_DIR}" \
  "${SOLILOQUY_LOG_DIR}" \
  "${SOLILOQUY_TERMINAL_STATE_DIR}"
chmod 700 "${XDG_RUNTIME_DIR}"
chmod 700 \
  "${XDG_DATA_HOME}" \
  "${XDG_CACHE_HOME}" \
  "${XDG_CONFIG_HOME}" \
  "${XDG_STATE_HOME}" \
  "${SOLILOQUY_PROFILE_DIR}" \
  "${SOLILOQUY_CACHE_DIR}" \
  "${SOLILOQUY_DOWNLOADS_DIR}" \
  "${SOLILOQUY_STATE_DIR}" \
  "${SOLILOQUY_LOG_DIR}" \
  "${SOLILOQUY_TERMINAL_STATE_DIR}"

log() {
  printf '[sol-session] %s\n' "$1" >&2
}

now_unix_ms() {
  printf '%s000\n' "$(date +%s)"
}

record_runtime_state() {
  key="$1"
  value="$2"
  tmp="${SOLILOQUY_RUNTIME_STATE_ENV}.$$"
  if [ -f "${SOLILOQUY_RUNTIME_STATE_ENV}" ]; then
    grep -v "^${key}=" "${SOLILOQUY_RUNTIME_STATE_ENV}" >"${tmp}" || true
  else
    : >"${tmp}"
  fi
  printf '%s=%s\n' "${key}" "${value}" >>"${tmp}"
  mv "${tmp}" "${SOLILOQUY_RUNTIME_STATE_ENV}"
}

attach_to_cgroup() {
  group="$1"
  pid="$2"
  path="/sys/fs/cgroup/soliloquy/${group}"
  if [ -f /sys/fs/cgroup/cgroup.controllers ] && mkdir -p "${path}" 2>/dev/null; then
    printf '%s\n' "${pid}" >"${path}/cgroup.procs" 2>/dev/null || true
  fi
}

wait_for_sold() {
  origin="${SOL_SOLD_ORIGIN:-http://127.0.0.1:8080}"
  retries="${SOL_SOLD_READY_RETRIES:-600}"
  i=0
  if ! command -v wget >/dev/null 2>&1; then
    log "wget not found; skipping sold readiness probe"
    return
  fi
  while ! wget -q -O /dev/null -T 1 -t 1 "${origin}/health" 2>/dev/null; do
    i=$((i + 1))
    if [ "${i}" -ge "${retries}" ]; then
      log "sold not ready before session launch (${origin}/health)"
      return
    fi
    sleep 0.1
  done
  log "sold ready (${origin}/health)"
  record_runtime_state SOLILOQUY_SOLD_READY_UNIX_MS "$(now_unix_ms)"
}

has_drm_device() {
  [ -e /dev/dri/card0 ] || [ -e /dev/dri/renderD128 ]
}

has_input_device() {
  [ -e /dev/input/mice ] || { set -- /dev/input/event*; [ -e "$1" ]; }
}

has_seatd_socket() {
  [ -S /run/seatd.sock ]
}

launch_session() {
  backend="$1"
  export WLR_BACKENDS="${backend}"
  if ! has_input_device; then
    export WLR_LIBINPUT_NO_DEVICES=1
    log "no input devices found; allowing wlroots to continue without libinput devices"
  fi
  log "WLR_BACKENDS=${WLR_BACKENDS}"
  log "WLR_RENDERER=${WLR_RENDERER}"
  log "SERVO_DISPLAY_BACKEND=${SERVO_DISPLAY_BACKEND}"
  log "XDG_SESSION_TYPE=${XDG_SESSION_TYPE}"
  log "WINIT_UNIX_BACKEND=${WINIT_UNIX_BACKEND}"
  log "EGL_PLATFORM=${EGL_PLATFORM}"
  log "SOLILOQUY_JS_ENGINE=${SOLILOQUY_JS_ENGINE:-v8-experimental}"

  if [ -c "${SERIAL_CONSOLE}" ]; then
    cage -- /usr/local/bin/sol-servo-wrapper >>"${SERIAL_CONSOLE}" 2>&1
  else
    cage -- /usr/local/bin/sol-servo-wrapper
  fi
}

log "XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR}"
log "SOLILOQUY_SYSTEM_CONFIG=${SOLILOQUY_SYSTEM_CONFIG}"
record_runtime_state SOLILOQUY_SESSION_START_UNIX_MS "$(now_unix_ms)"
attach_to_cgroup browser "$$"

if ! has_drm_device; then
  if [ "${SOL_SESSION_HEADLESS_FALLBACK:-1}" = "1" ]; then
    export WLR_BACKENDS=headless
    export WLR_LIBINPUT_NO_DEVICES=1
    log "no DRM device found; using wlroots headless backend"
  else
    log "no DRM device found; cannot start Wayland appliance"
    exit 1
  fi
fi

if ! has_seatd_socket && [ "${WLR_BACKENDS}" != "headless" ]; then
  log "seatd socket not found at /run/seatd.sock; cannot start Wayland appliance"
  exit 1
fi

if ! command -v cage >/dev/null 2>&1; then
  log "cage not found; cannot start Wayland appliance"
  exit 1
fi

if [ "${WLR_BACKENDS}" = "headless" ]; then
  log "using cage with wlroots headless backend"
else
  log "DRM device found; using cage (Wayland)"
fi
wait_for_sold
set +e
launch_session "${WLR_BACKENDS:-drm,libinput}"
status=$?
set -e

# If the session was started with native Wayland winit, retry once with X11 (XWayland).
if [ "${status}" != 0 ] && [ "${SOL_SESSION_X11_FALLBACK:-0}" = "1" ] && [ "${WINIT_UNIX_BACKEND}" != "x11" ]; then
  log "session exited ${status}; retrying with X11 client backend via XWayland (WINIT_UNIX_BACKEND=x11)"
  export WINIT_UNIX_BACKEND=x11
  export DISPLAY="${DISPLAY:-:0}"
  export EGL_PLATFORM="${SOL_SESSION_X11_EGL_PLATFORM:-x11}"
  set +e
  launch_session "${WLR_BACKENDS:-drm,libinput}"
  status=$?
  set -e
fi

log "Wayland session exited with status ${status}"
if [ "${status}" != 0 ]; then
  delay="${SOL_SESSION_FAILURE_DELAY:-8}"
  log "non-zero exit; sleeping ${delay}s before returning (reduces inittab respawn tight-loop)"
  sleep "${delay}"
fi
exit "${status}"
