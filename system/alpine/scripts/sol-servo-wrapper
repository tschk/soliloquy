#!/bin/sh
set -eu

SOLILOQUY_RUNTIME_ENV="${SOLILOQUY_RUNTIME_ENV:-/var/lib/soliloquy/files/runtime.env}"
if [ -f "${SOLILOQUY_RUNTIME_ENV}" ]; then
  . "${SOLILOQUY_RUNTIME_ENV}"
fi
SOLILOQUY_RUNTIME_STATE_ENV="${SOLILOQUY_RUNTIME_STATE_ENV:-/run/soliloquy/runtime-state.env}"
SOLILOQUY_RUNTIME_EVENTS_FILE="${SOLILOQUY_RUNTIME_EVENTS_FILE:-/run/soliloquy/runtime-events.log}"
mkdir -p "$(dirname "${SOLILOQUY_RUNTIME_STATE_ENV}")"
mkdir -p "$(dirname "${SOLILOQUY_RUNTIME_EVENTS_FILE}")"

START_URL="${SOL_START_URL:-os://terminal}"
# Terminal UI from sold (same HTML as bundle/terminal — black chrome + canvas). Override with SOL_LAUNCH_URL.
SOL_SOLD_ORIGIN="${SOL_SOLD_ORIGIN:-http://127.0.0.1:8080}"
case "${START_URL}" in
  os://*)
    PROBE_URL="${SOL_SOLD_ORIGIN}/health"
    LAUNCH_URL="${SOL_LAUNCH_URL:-${SOL_SOLD_ORIGIN}/?url=${START_URL}}"
    ;;
  *)
    PROBE_URL="${START_URL}"
    LAUNCH_URL="${START_URL}"
    ;;
esac

SERVO_BIN="${SERVO_BIN:-/usr/local/bin/servo}"
SERVO_DISPLAY_BACKEND="${SERVO_DISPLAY_BACKEND:-wayland}"
SOLILOQUY_JS_ENGINE="${SOLILOQUY_JS_ENGINE:-v8-experimental}"
SOL_SERVO_HEADLESS="${SOL_SERVO_HEADLESS:-0}"
SOL_SERVO_DEBUG_DUMP="${SOL_SERVO_DEBUG_DUMP:-0}"
SOL_SERVO_VERBOSE="${SOL_SERVO_VERBOSE:-0}"
SOL_SERVO_LOG_FILTER="${SOL_SERVO_LOG_FILTER:-1}"
SOL_SERVO_NO_BROWSER_CHROME="${SOL_SERVO_NO_BROWSER_CHROME:-1}"

export LIBGL_ALWAYS_SOFTWARE="${LIBGL_ALWAYS_SOFTWARE:-1}"
export LIBGL_DRI3_DISABLE="${LIBGL_DRI3_DISABLE:-1}"
export LIBGL_DRIVERS_PATH="${LIBGL_DRIVERS_PATH:-/usr/lib/dri}"
export SOLILOQUY_SURFMAN_SOFTWARE="${SOLILOQUY_SURFMAN_SOFTWARE:-1}"
export SOLILOQUY_SURFMAN_CONNECTION_NEW="${SOLILOQUY_SURFMAN_CONNECTION_NEW:-0}"
export SOLILOQUY_JS_ENGINE

export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export WINIT_UNIX_BACKEND="${WINIT_UNIX_BACKEND:-wayland}"
export EGL_PLATFORM="${EGL_PLATFORM:-wayland}"
case "${WINIT_UNIX_BACKEND}" in
  x11)
    export DISPLAY="${DISPLAY:-:0}"
    export EGL_PLATFORM="${EGL_PLATFORM:-x11}"
    _xsock="/tmp/.X11-unix/X${DISPLAY#:}"
    _i=0
    while [ ! -S "${_xsock}" ] && [ "${_i}" -lt 100 ]; do
      sleep 0.05
      _i=$((_i + 1))
    done
    unset WAYLAND_DISPLAY 2>/dev/null || true
    ;;
  *)
    unset DISPLAY
    ;;
esac

case "${SOL_SERVO_HEADLESS}" in
  1|true|TRUE|yes|YES)
    export EGL_PLATFORM="surfaceless"
    export GALLIUM_DRIVER="${GALLIUM_DRIVER:-softpipe}"
    export LP_NUM_THREADS="${LP_NUM_THREADS:-1}"
    export MESA_LOADER_DRIVER_OVERRIDE="${MESA_LOADER_DRIVER_OVERRIDE:-swrast}"
    ;;
  *)
    export GALLIUM_DRIVER="${GALLIUM_DRIVER:-llvmpipe}"
    export MESA_LOADER_DRIVER_OVERRIDE="${MESA_LOADER_DRIVER_OVERRIDE:-swrast}"
    ;;
esac

# Quiet default; SOL_SERVO_VERBOSE=1 or explicit RUST_LOG for deep traces.
if [ "${SOL_SERVO_VERBOSE}" = "1" ]; then
  export RUST_LOG="${RUST_LOG:-info,servoshell=debug,winit=debug}"
  export RUST_BACKTRACE="${RUST_BACKTRACE:-1}"
else
  export RUST_LOG="${RUST_LOG:-warn,servoshell=info,winit=warn}"
  export RUST_BACKTRACE="${RUST_BACKTRACE:-0}"
fi
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"

# One sink only: parent (cage) usually redirects stderr to serial — avoid duplicate lines.
log() {
  printf '[sol-servo] %s\n' "$1" >&2
}

filter_servo_logs() {
  if [ "${SOL_SERVO_VERBOSE}" = "1" ] || [ "${SOL_SERVO_LOG_FILTER}" = "0" ] || ! command -v awk >/dev/null 2>&1; then
    cat
    return
  fi
  awk '
    /^\[sol-servo\] pump_servo_event_loop start$/ { next }
    /^\[sol-servo\] pump_servo_event_loop end$/ { next }
    /^\[sol-servo\] running_app_state\.spin_event_loop start$/ { next }
    /^\[sol-servo\] running_app_state\.spin_event_loop after servo\.spin_event_loop$/ { next }
    /^\[sol-servo\] winit about_to_wait$/ { next }
    /^\[sol-servo\] winit user_event: Waker$/ { next }
    /^\[sol-servo\] winit window_event: RedrawRequested$/ { next }
    /^\[sol-servo\] request_repaint:/ { next }
    /^\[sol-servo\] gui\.paint begin:/ { next }
    /^\[sol-servo\] redraw requested:.*title=Soliloquy( Shell)?$/ { if (ready_redraw_seen++) next; print; next }
    /^\[sol-servo\] redraw requested:/ { if (early_redraw_seen++) next }
    /^\[sol-servo\] gui\.paint end$/ { if (paint_seen++) next }
    { print; fflush() }
  '
}

start_servo() {
  if [ "${SOL_SERVO_VERBOSE}" = "1" ] || [ "${SOL_SERVO_LOG_FILTER}" = "0" ] || ! command -v mkfifo >/dev/null 2>&1; then
    if [ -c "${SERIAL_CONSOLE}" ]; then
      "$@" >>"${SERIAL_CONSOLE}" 2>&1 &
    else
      "$@" &
    fi
    servo_pid=$!
    servo_log_filter_pid=""
    return
  fi

  log_fifo="/run/soliloquy/servo-log.$$"
  rm -f "${log_fifo}"
  mkfifo "${log_fifo}"
  if [ -c "${SERIAL_CONSOLE}" ]; then
    filter_servo_logs <"${log_fifo}" >>"${SERIAL_CONSOLE}" &
  else
    filter_servo_logs <"${log_fifo}" &
  fi
  servo_log_filter_pid=$!
  "$@" >"${log_fifo}" 2>&1 &
  servo_pid=$!
  rm -f "${log_fifo}"
}

now_unix_ms() {
  printf '%s000\n' "$(date +%s)"
}

record_runtime_state() {
  key="$1"
  value="$2"
  tmp="${SOLILOQUY_RUNTIME_STATE_ENV}.$$"
  if [ -f "${SOLILOQUY_RUNTIME_STATE_ENV}" ]; then
    grep -v "^${key}=" "${SOLILOQUY_RUNTIME_STATE_ENV}" >"${tmp}" || true
  else
    : >"${tmp}"
  fi
  printf '%s=%s\n' "${key}" "${value}" >>"${tmp}"
  mv "${tmp}" "${SOLILOQUY_RUNTIME_STATE_ENV}"
}

record_runtime_event() {
  kind="$1"
  source="$2"
  detail="${3:-}"
  printf '%s\t%s\t%s\t%s\n' "$(now_unix_ms)" "${kind}" "${source}" "${detail}" >>"${SOLILOQUY_RUNTIME_EVENTS_FILE}" 2>/dev/null || true
}

runtime_state_value() {
  key="$1"
  if [ -f "${SOLILOQUY_RUNTIME_STATE_ENV}" ]; then
    grep "^${key}=" "${SOLILOQUY_RUNTIME_STATE_ENV}" | tail -n 1 | cut -d= -f2-
  fi
}

attach_to_cgroup() {
  group="$1"
  pid="$2"
  if [ -x /usr/local/bin/sol-kernelctl ]; then
    /usr/local/bin/sol-kernelctl attach --group "${group}" --pid "${pid}" >/dev/null 2>&1 || true
    return
  fi
  path="/sys/fs/cgroup/soliloquy/${group}"
  if [ -f /sys/fs/cgroup/cgroup.controllers ] && mkdir -p "${path}" 2>/dev/null; then
    printf '%s\n' "${pid}" >"${path}/cgroup.procs" 2>/dev/null || true
  fi
}

dump_servo_process_state() {
  pid="$1"
  if [ ! -d "/proc/${pid}" ]; then
    log "proc entry missing for pid=${pid}"
    return
  fi
  if [ -r "/proc/${pid}/status" ]; then
    grep -E '^(State|VmRSS|Threads):' "/proc/${pid}/status" 2>/dev/null | while IFS= read -r line; do
      log "proc status: ${line}"
    done || true
  fi
  case "${SOL_SERVO_DEBUG_DUMP}" in
    1|true|TRUE|yes|YES) ;;
    *) return ;;
  esac
  for proc_file in wchan syscall stack; do
    if [ -r "/proc/${pid}/${proc_file}" ]; then
      while IFS= read -r line; do
        log "proc ${proc_file}: ${line}"
      done <"/proc/${pid}/${proc_file}" 2>/dev/null || true
    fi
  done
  if [ -d "/proc/${pid}/fd" ]; then
    ls -l "/proc/${pid}/fd" 2>&1 | while IFS= read -r line; do
      log "proc fd: ${line}"
    done || true
  fi
  if [ -r "/proc/${pid}/maps" ]; then
    grep -E 'dri|gallium|swrast|libwayland|libEGL|libGLES|libGL|libxkbcommon|libdrm|libgbm|LLVM' "/proc/${pid}/maps" 2>/dev/null | while IFS= read -r line; do
      log "proc map: ${line}"
    done || true
  fi
}

if [ "${SOL_SERVO_VERBOSE}" = "1" ]; then
  log "START_URL=${START_URL} LAUNCH_URL=${LAUNCH_URL}"
  log "servo=${SERVO_BIN} DISPLAY=${DISPLAY:-} WAYLAND=${WAYLAND_DISPLAY:-} EGL_PLATFORM=${EGL_PLATFORM}"
  log "RUST_LOG=${RUST_LOG}"
  if [ -f /etc/resolv.conf ]; then
    while IFS= read -r line; do
      log "resolv.conf: ${line}"
    done </etc/resolv.conf
  fi
  if command -v ip >/dev/null 2>&1; then
    ip route 2>&1 | while IFS= read -r line; do
      log "ip route: ${line}"
    done || true
  fi
  if [ -d "${XDG_RUNTIME_DIR:-}" ]; then
    ls -la "${XDG_RUNTIME_DIR}" 2>&1 | while IFS= read -r line; do
      log "runtime: ${line}"
    done || true
  fi
fi

if command -v wget >/dev/null 2>&1; then
  probe_i=0
  while ! wget -q -O /dev/null -T 1 -t 1 "${PROBE_URL}" 2>/dev/null; do
    probe_i=$((probe_i + 1))
    if [ "${probe_i}" -ge "${SOL_SOLD_PROBE_RETRIES:-600}" ]; then
      log "warn: sold probe failed (${PROBE_URL}); continuing"
      if [ "${SOL_SERVO_VERBOSE}" = "1" ]; then
        wget -S -O /dev/null -T 5 -t 1 "${PROBE_URL}" 2>&1 | while IFS= read -r line; do log "wget: ${line}"; done || true
      fi
      break
    fi
    sleep 0.1
  done
  if [ "${probe_i}" -lt "${SOL_SOLD_PROBE_RETRIES:-600}" ]; then
    log "sold reachable (${PROBE_URL})"
    record_runtime_state SOLILOQUY_SOLD_PROBE_UNIX_MS "$(now_unix_ms)"
    record_runtime_event sold_probe sol-servo-wrapper "${PROBE_URL}"
  fi
fi

if [ ! -x "${SERVO_BIN}" ]; then
  log "servo binary missing: ${SERVO_BIN}"
  exit 1
fi

set -- "${SERVO_BIN}"
case "${SOL_SERVO_NO_BROWSER_CHROME}" in
  1|true|TRUE|yes|YES) set -- "$@" --no-browser-chrome ;;
esac
case "${SOL_SERVO_HEADLESS}" in
  1|true|TRUE|yes|YES) set -- "$@" --headless ;;
esac
set -- "$@" "${LAUNCH_URL}"

SERIAL_CONSOLE="${SERIAL_CONSOLE:-/dev/ttyS0}"
record_runtime_state SOLILOQUY_BROWSER_LAUNCH_UNIX_MS "$(now_unix_ms)"
record_runtime_event browser_launch sol-servo-wrapper "${LAUNCH_URL}"
start_servo "$@"
record_runtime_state SOLILOQUY_SERVO_SPAWN_UNIX_MS "$(now_unix_ms)"
record_runtime_state SOLILOQUY_RENDERER_PID "${servo_pid}"
record_runtime_event servo_spawn sol-servo-wrapper "${servo_pid}"
attach_to_cgroup foreground-renderer "${servo_pid}"

if [ "${SOL_SERVO_VERBOSE}" = "1" ]; then
  log "servo pid=${servo_pid} (verbose poll)"
  sleep 2
  if kill -0 "${servo_pid}" 2>/dev/null; then
    log "servo alive at 2s"
    dump_servo_process_state "${servo_pid}"
  else
    log "servo died before 2s"
  fi
  sleep 4
  if kill -0 "${servo_pid}" 2>/dev/null; then
    log "servo alive at 6s"
  else
    log "servo died before 6s"
  fi
fi

set +e
wait "${servo_pid}"
status=$?
if [ -n "${servo_log_filter_pid:-}" ]; then
  wait "${servo_log_filter_pid}" 2>/dev/null || true
fi
set -e
record_runtime_state SOLILOQUY_BROWSER_EXIT_UNIX_MS "$(now_unix_ms)"
record_runtime_state SOLILOQUY_LAST_RENDERER_EXIT "${status}"
record_runtime_event browser_exit sol-servo-wrapper "${status}"
renderer_restarts="$(runtime_state_value SOLILOQUY_RENDERER_RESTARTS)"
case "${renderer_restarts}" in
  ''|*[!0-9]*) renderer_restarts=0 ;;
esac
record_runtime_state SOLILOQUY_RENDERER_RESTARTS "$((renderer_restarts + 1))"
if [ "${status}" != 0 ] || [ "${SOL_SERVO_VERBOSE}" = "1" ]; then
  log "servo exited status ${status}"
fi
if [ "${status}" != 0 ] && [ "${SOL_SERVO_VERBOSE}" != "1" ]; then
  dump_servo_process_state "${servo_pid}" 2>/dev/null || true
fi
exit "${status}"
