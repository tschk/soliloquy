#!/bin/sh
set -eu

START_URL="${SOL_START_URL:-os://terminal}"
SPLASH_URL="file:///usr/local/share/soliloquy/splash/index.html#${START_URL}"
case "${START_URL}" in
  os://terminal) PROBE_URL="http://127.0.0.1:8080/terminal" ;;
  os://files) PROBE_URL="http://127.0.0.1:8080/files.html" ;;
  os://settings) PROBE_URL="http://127.0.0.1:8080/settings.html" ;;
  *) PROBE_URL="${START_URL}" ;;
esac
SERIAL_CONSOLE="${SERIAL_CONSOLE:-/dev/ttyS0}"
SERVO_BIN="${SERVO_BIN:-/usr/local/bin/servo}"
SERVO_DISPLAY_BACKEND="${SERVO_DISPLAY_BACKEND:-x11}"
SOLILOQUY_JS_ENGINE="${SOLILOQUY_JS_ENGINE:-v8-experimental}"
SOL_SERVO_HEADLESS="${SOL_SERVO_HEADLESS:-0}"
SOL_SERVO_DEBUG_DUMP="${SOL_SERVO_DEBUG_DUMP:-0}"
export LIBGL_ALWAYS_SOFTWARE="${LIBGL_ALWAYS_SOFTWARE:-1}"
export LIBGL_DRI3_DISABLE="${LIBGL_DRI3_DISABLE:-1}"
export LIBGL_DRIVERS_PATH="${LIBGL_DRIVERS_PATH:-/usr/lib/xorg/modules/dri:/usr/lib/dri}"
export SOLILOQUY_SURFMAN_SOFTWARE="${SOLILOQUY_SURFMAN_SOFTWARE:-1}"
export SOLILOQUY_SURFMAN_CONNECTION_NEW="${SOLILOQUY_SURFMAN_CONNECTION_NEW:-0}"
export SOLILOQUY_SURFMAN_X11_LEGACY_EGL="${SOLILOQUY_SURFMAN_X11_LEGACY_EGL:-1}"
export SOLILOQUY_JS_ENGINE

case "${SERVO_DISPLAY_BACKEND}" in
  x11)
    export XDG_SESSION_TYPE="x11"
    export WINIT_UNIX_BACKEND="x11"
    export EGL_PLATFORM="x11"
    unset WAYLAND_DISPLAY
    ;;
  wayland)
    export XDG_SESSION_TYPE="wayland"
    export WINIT_UNIX_BACKEND="wayland"
    export EGL_PLATFORM="wayland"
    unset DISPLAY
    ;;
esac
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-x11}"
export WINIT_UNIX_BACKEND="${WINIT_UNIX_BACKEND:-x11}"
export EGL_PLATFORM="${EGL_PLATFORM:-x11}"

case "${SOL_SERVO_HEADLESS}" in
  1|true|TRUE|yes|YES)
    export EGL_PLATFORM="surfaceless"
    export GALLIUM_DRIVER="${GALLIUM_DRIVER:-softpipe}"
    export LP_NUM_THREADS="${LP_NUM_THREADS:-1}"
    export MESA_LOADER_DRIVER_OVERRIDE="${MESA_LOADER_DRIVER_OVERRIDE:-swrast}"
    ;;
  *)
    export GALLIUM_DRIVER="${GALLIUM_DRIVER:-llvmpipe}"
    export MESA_LOADER_DRIVER_OVERRIDE="${MESA_LOADER_DRIVER_OVERRIDE:-swrast}"
    ;;
esac
export RUST_LOG="${RUST_LOG:-info,servoshell=trace,servoshell<winit@=trace,constellation=trace,script=info,net=debug,compositing=trace,fonts=info}"
export RUST_BACKTRACE="${RUST_BACKTRACE:-1}"
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"

log() {
  line="[sol-servo] $1"
  echo "${line}" >&2
  if [ -c "${SERIAL_CONSOLE}" ]; then
    echo "${line}" >"${SERIAL_CONSOLE}" 2>/dev/null || true
  fi
}

dump_servo_process_state() {
  pid="$1"
  if [ ! -d "/proc/${pid}" ]; then
    log "proc entry missing for pid=${pid}"
    return
  fi

  if [ -r "/proc/${pid}/status" ]; then
    grep -E '^(State|VmRSS|Threads):' "/proc/${pid}/status" 2>/dev/null | while IFS= read -r line; do
      log "proc status: ${line}"
    done || true
  fi

  case "${SOL_SERVO_DEBUG_DUMP}" in
    1|true|TRUE|yes|YES) ;;
    *) return ;;
  esac

  for proc_file in wchan syscall stack; do
    if [ -r "/proc/${pid}/${proc_file}" ]; then
      while IFS= read -r line; do
        log "proc ${proc_file}: ${line}"
      done <"/proc/${pid}/${proc_file}" 2>/dev/null || true
    fi
  done

  if [ -d "/proc/${pid}/fd" ]; then
    ls -l "/proc/${pid}/fd" 2>&1 | while IFS= read -r line; do
      log "proc fd: ${line}"
    done || true
  fi

  if [ -r "/proc/${pid}/maps" ]; then
    grep -E 'dri|gallium|swrast|libwayland|libEGL|libGLES|libGL|libxkbcommon|libdrm|libgbm|LLVM' "/proc/${pid}/maps" 2>/dev/null | while IFS= read -r line; do
      log "proc map: ${line}"
    done || true
  fi
}

log "starting Servo at ${START_URL}"
log "splash url: ${SPLASH_URL}"
log "servo binary: ${SERVO_BIN}"
log "SERVO_DISPLAY_BACKEND=${SERVO_DISPLAY_BACKEND}"
log "RUST_LOG=${RUST_LOG}"
log "XDG_SESSION_TYPE=${XDG_SESSION_TYPE}"
log "WINIT_UNIX_BACKEND=${WINIT_UNIX_BACKEND}"
log "EGL_PLATFORM=${EGL_PLATFORM:-<unset>}"
log "WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-<unset>}"
log "DISPLAY=${DISPLAY:-<unset>}"
log "GALLIUM_DRIVER=${GALLIUM_DRIVER}"
log "LP_NUM_THREADS=${LP_NUM_THREADS:-<unset>}"
log "MESA_LOADER_DRIVER_OVERRIDE=${MESA_LOADER_DRIVER_OVERRIDE:-<unset>}"
log "LIBGL_DRI3_DISABLE=${LIBGL_DRI3_DISABLE}"
log "LIBGL_DRIVERS_PATH=${LIBGL_DRIVERS_PATH}"
log "SOLILOQUY_SURFMAN_SOFTWARE=${SOLILOQUY_SURFMAN_SOFTWARE}"
log "SOLILOQUY_SURFMAN_CONNECTION_NEW=${SOLILOQUY_SURFMAN_CONNECTION_NEW}"
log "SOLILOQUY_SURFMAN_X11_LEGACY_EGL=${SOLILOQUY_SURFMAN_X11_LEGACY_EGL}"
log "SOLILOQUY_JS_ENGINE=${SOLILOQUY_JS_ENGINE}"
log "SOL_SERVO_HEADLESS=${SOL_SERVO_HEADLESS}"
log "SOL_SERVO_DEBUG_DUMP=${SOL_SERVO_DEBUG_DUMP}"

if [ -f /etc/resolv.conf ]; then
  while IFS= read -r line; do
    log "resolv.conf: ${line}"
  done </etc/resolv.conf
fi

if command -v ip >/dev/null 2>&1; then
  ip route 2>&1 | while IFS= read -r line; do
    log "ip route: ${line}"
  done || true
fi

if [ -d "${XDG_RUNTIME_DIR:-}" ]; then
  ls -la "${XDG_RUNTIME_DIR}" 2>&1 | while IFS= read -r line; do
    log "runtime dir: ${line}"
  done || true
fi

if command -v wget >/dev/null 2>&1; then
  log "starting background wget probe for ${PROBE_URL}"
  (
    if wget_output="$(wget -S -O /dev/null -T 5 -t 1 "${PROBE_URL}" 2>&1)"; then
      printf '%s\n' "${wget_output}" | while IFS= read -r line; do log "wget: ${line}"; done
      log "wget probe succeeded"
    else
      printf '%s\n' "${wget_output}" | while IFS= read -r line; do log "wget: ${line}"; done
      log "wget probe failed; continuing to Servo anyway"
    fi
  ) &
else
  log "wget not available; skipping HTTP probe"
fi

if [ ! -x "${SERVO_BIN}" ]; then
  log "servo binary not found at ${SERVO_BIN}; cannot start browser appliance"
  exit 1
fi

set -- "${SERVO_BIN}"
case "${SOL_SERVO_HEADLESS}" in
  1|true|TRUE|yes|YES) set -- "$@" --headless ;;
esac
set -- "$@" "${SPLASH_URL}"

if [ -c "${SERIAL_CONSOLE}" ]; then
  "$@" >>"${SERIAL_CONSOLE}" 2>&1 &
else
  "$@" &
fi
servo_pid=$!
log "servo pid=${servo_pid}"

sleep 2
if kill -0 "${servo_pid}" 2>/dev/null; then
  log "servo still running after 2s"
  dump_servo_process_state "${servo_pid}"
else
  log "servo exited before 2s"
fi

sleep 4
if kill -0 "${servo_pid}" 2>/dev/null; then
  log "servo still running after 6s"
else
  log "servo exited before 6s"
fi

wait "${servo_pid}"
status=$?
log "servo exited with status ${status}"
exit "${status}"
